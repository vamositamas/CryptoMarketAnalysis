{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/web/src",
  "tags": ["type:app", "scope:frontend"],
  "i18n": {
    "sourceLocale": {
      "code": "en",
      "baseHref": "/en/"
    },
    "locales": {
      "hu": {
        "translation": "apps/web/src/locale/messages.hu.xlf",
        "baseHref": "/hu/"
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/web",
        "browser": "apps/web/src/main.ts",
        "polyfills": ["@angular/localize/init"],
        "tsConfig": "apps/web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/web/public"
          }
        ],
        "styles": ["apps/web/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "production-en": {
          "localize": ["en"],
          "baseHref": "/en/",
          "outputHashing": "all"
        },
        "production-hu": {
          "localize": ["hu"],
          "baseHref": "/hu/",
          "outputHashing": "all"
        },
        "production-i18n": {
          "localize": true,
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "proxyConfig": "apps/web/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "web:build:production"
        },
        "development": {
          "buildTarget": "web:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "web:build:development",
        "format": "xlf",
        "outputPath": "apps/web/src/locale",
        "outFile": "messages.xlf"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/web/jest.config.cts",
        "tsConfig": "apps/web/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web:build",
        "staticFilePath": "dist/apps/web/browser",
        "spa": true
      }
    }
  }
}
