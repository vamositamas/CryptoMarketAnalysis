# Supabase PostgreSQL connection string.
# Project URL and publishable API key are used for Supabase client integrations.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_<key>"

# Supabase PostgreSQL connection string.
# Use the Supavisor transaction-mode pooler URL for serverless/runtime traffic.
SUPABASE_DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Optional direct database URL for local migrations and administrative tasks.
# Keep this out of deployed serverless runtime configuration.
SUPABASE_DIRECT_DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Used to sign stateless CSRF tokens. Generate a long random value per environment.
CSRF_SECRET="<long-random-csrf-secret>"

# Used to sign JWT access tokens. Generate a long random value per environment.
JWT_SECRET="<long-random-jwt-secret>"

# Google OAuth 2.0 backend credentials.
GOOGLE_CLIENT_ID="<google-oauth-client-id>"
GOOGLE_CLIENT_SECRET="<google-oauth-client-secret>"
GOOGLE_REDIRECT_URI="http://localhost:3111/api/auth/google/callback"
FRONTEND_URL="http://localhost:4200"

# Upstash Redis REST API credentials for caching, sessions, and rate limiting.
UPSTASH_REDIS_URL="https://<redis-id>.<region>.upstash.io"
UPSTASH_REDIS_TOKEN="<upstash-redis-token>"

# Upstash QStash credentials for scheduled/background HTTP jobs.
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="<qstash-token>"

# Resend transactional email API key.
RESEND_API_KEY="re_<api-key>"
RESEND_FROM_EMAIL="CryptoMarketAnalysis <noreply@cryptomarketanalysis.com>"
