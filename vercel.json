{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx nx build web --configuration=production-i18n && npx esbuild api/_handler.ts --bundle --packages=external --platform=node --target=node20 --outfile=api/index.js --tsconfig=api/tsconfig.json --format=cjs",
  "outputDirectory": "dist/apps/web/browser",
  "framework": "angular",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/",
      "destination": "/en/locale-redirect.html"
    },
    {
      "source": "/en/(.*)",
      "destination": "/en/index.html"
    },
    {
      "source": "/hu/(.*)",
      "destination": "/hu/index.html"
    }
  ]
}
